# Environment Variables Template
# Copy this file to .env and fill in your actual values
# The .env file is gitignored to keep your secrets safe

# ============================================================================
# API Keys
# ============================================================================

# Polygon.io API Key (Required for data fetching)
# Get your free API key at: https://polygon.io/
# Free tier: 5 API calls/minute, ~250 calls/day
# Paste your key after the equals sign (no quotes needed)
POLYGON_API_KEY=your_polygon_api_key_here

# ============================================================================
# Optional Configuration
# ============================================================================

# Network Access Control (Optional)
# Set to "1" to enable network data fetching
# Set to "0" or leave unset to disable (offline mode with cached data)
# Default: unset (network disabled)
# ALLOW_NETWORK=1

# ============================================================================
# Setup Instructions
# ============================================================================
#
# 1. Copy this template to create your .env file:
#    cp .env.template .env
#
# 2. Get a Polygon API key:
#    - Go to https://polygon.io/
#    - Sign up for free account
#    - Copy your API key from dashboard
#
# 3. Edit .env and replace 'your_polygon_api_key_here' with your actual key
#
# 4. (Optional) Enable network access:
#    echo "ALLOW_NETWORK=1" >> .env
#
# 5. Verify setup:
#    python -c "from dotenv import load_dotenv; import os; load_dotenv(); print('OK' if os.getenv('POLYGON_API_KEY') else 'Missing API key')"
#
# ============================================================================
# Security Notes
# ============================================================================
#
# - Never commit .env to git (it's in .gitignore)
# - Never share your API keys publicly
# - Rotate keys if accidentally exposed
# - Use environment-specific .env files (.env.dev, .env.prod) if needed
#
