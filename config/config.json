{
  "ticker": "SPY",
  "tickers": [
    "SPY"
  ],
  "lookback_years": 10,
  "premium_budget": 100,
  "default_take_profit_atr": 0.1,
  "rate_limit_seconds": 14,
  "max_requests_per_run": 10000,
  "max_requests_per_minute": 90,
  "spx_value": null,
  "spx_ratio": null,

  "filters": {
    "exclude_fridays": true,
    "exclude_flat_days": true,
    "enable_fade_green": false,
    "enable_fade_red": true,
    "min_magnitude_pct": 0.10
  },

  "position_sizing": {
    "method": "half_kelly",
    "risk_pct_per_trade": 0.01,
    "daily_cap_pct": 0.02,
    "weekly_cap_pct": 0.07,
    "starting_equity": 10000,
    "notes": "1% equity per trade premium budget; daily/weekly caps prevent overexposure"
  },

  "cost_model": {
    "active": "pct",
    "note": "Switch to 'fixed' after spread sampling calibration is complete",
    "percentage": {
      "ig_spread_pct": 0.04,
      "ig_slippage_pct": 0.01,
      "total_round_trip_pct": 0.05,
      "source": "baseline_atm_vixiv.json (frozen 2026-02-08)"
    },
    "fixed_point": {
      "config_file": "config/cost_model_fixed.json",
      "note": "Generated by analyze_spread_samples.py after IG spread sampling",
      "status": "pending — run collect_ig_spreads.py first"
    }
  },

  "ig_api": {
    "underlying_epic": "IX.D.SPTRD.DAILY.IP",
    "option_epic_pattern": "OP.D.{expiry_code}.{strike}{type}.IP",
    "expiry_codes": {
      "MON-WED": "SPXWED",
      "TUE-WED": "SPXWED",
      "WED-FRI": "SPXFRI",
      "THU-FRI": "SPXFRI",
      "FRI-MON": "SPXMON"
    },
    "option_type_codes": {
      "CALL": "C",
      "PUT": "P"
    },
    "strike_increment": 5,
    "notes": "SPXFRI may show as SPXEMO on month-end Fridays; collector probes both each run"
  },

  "directories": {
    "data": "data",
    "logs": "logs",
    "results": "results"
  },

  "vix_ticker": "VIX",
  "sector_etfs": [
    "XLK", "XLF", "XLE", "XLV", "XLY", "XLU", "XLRE", "XLI", "XLB"
  ],
  "multi_ticker_enabled": true
}
